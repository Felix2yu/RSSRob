# Copy to .env (gitignored) and fill in your values, or export these as real
# environment variables. Used by rssrob.notify to send email notifications.

RSSROB_SMTP_HOST=smtp.gmail.com
RSSROB_SMTP_PORT=587
RSSROB_SMTP_STARTTLS=true            # or RSSROB_SMTP_SSL=true for port 465
RSSROB_SMTP_USER=you@gmail.com
RSSROB_SMTP_FROM=you@gmail.com       # optional, defaults to RSSROB_SMTP_USER

# Gmail: create an App Password at https://myaccount.google.com/apppasswords
RSSROB_SMTP_PASSWORD=
